# ─── Convex ───────────────────────────────────────────────────────────────────
# Found in your Convex dashboard after running `npx convex dev`
NEXT_PUBLIC_CONVEX_URL=https://<your-deployment>.convex.cloud

# Set automatically by Convex Auth — do not edit by hand
CONVEX_SITE_URL=https://<your-deployment>.convex.site

# ─── Convex Auth ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Set this in Convex dashboard → Settings → Environment Variables
JWT_PRIVATE_KEY=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://<your-deployment>.convex.site/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
