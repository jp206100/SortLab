# ─── Convex ───────────────────────────────────────────────────────────────────
# Found in your Convex dashboard after running `npx convex dev`
NEXT_PUBLIC_CONVEX_URL=https://<your-deployment>.convex.cloud

# The Convex HTTP actions base URL (ends in .convex.site)
CONVEX_SITE_URL=https://<your-deployment>.convex.site

# Your Next.js app's public URL — used by Convex Auth to redirect after OAuth
# In production: your Vercel URL. In dev: http://localhost:3000
SITE_URL=https://<your-app>.vercel.app

# ─── Convex Auth ──────────────────────────────────────────────────────────────
# Generate an RSA-2048 private key in PKCS8 PEM format:
#   node -e "const {privateKey}=require('crypto').generateKeyPairSync('rsa',{modulusLength:2048});console.log(privateKey.export({type:'pkcs8',format:'pem'}))"
# Paste the ENTIRE multi-line output (including BEGIN/END lines) into
# Convex dashboard → Settings → Environment Variables → JWT_PRIVATE_KEY
JWT_PRIVATE_KEY=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://<your-deployment>.convex.site/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
